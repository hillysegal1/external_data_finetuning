import os
import cv2
import numpy as np
import yaml
from pathlib import Path

src_img = "dataset/images/train_no_civ"
src_lbl = "dataset/labels/train_no_civ"
dst_img = "dataset/images/train_no_civ_aug_x1"
dst_lbl = "dataset/labels/train_no_civ_aug_x1"

os.makedirs(dst_img, exist_ok=True)
os.makedirs(dst_lbl, exist_ok=True)

MIN_BRIGHTNESS = 20
SHARPNESS_THRESHOLD = 200
n_augmentations = 1

def get_quality(img_path):
    img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
    if img is None:
        return None, None
    return np.mean(img), cv2.Laplacian(img, cv2.CV_64F).var()

def apply_gamma(img, gamma):
    inv_gamma = 1.0 / gamma
    table = np.array([((i / 255.0) ** inv_gamma) * 255
                      for i in range(256)]).astype(np.uint8)
    return cv2.LUT(img, table)

def augment_image(img, brightness_score, sharpness):
    aug = img.copy()

    # Gamma correction — always applied, no probability gate
    # Range depends on original brightness
    if brightness_score < 80:
        # Already dark — only brighten, never darken further
        gamma = np.random.uniform(0.7, 1.0)
    elif brightness_score > 150:
        # Bright frame — full range
        gamma = np.random.uniform(0.5, 1.5)
    else:
        # Middle range — skew toward darkening
        gamma = np.random.uniform(0.5, 1.2)

    aug = apply_gamma(aug, gamma)

    # Blur — only if sharp enough, 50% chance
    if sharpness > SHARPNESS_THRESHOLD and np.random.random() < 0.5:
        blur_type = np.random.choice(['gaussian', 'motion'])
        if blur_type == 'gaussian':
            ksize = np.random.choice([3, 5])
            aug = cv2.GaussianBlur(aug, (ksize, ksize), 0)
        else:
            ksize = np.random.choice([3, 5])
            kernel = np.zeros((ksize, ksize))
            kernel[ksize // 2, :] = np.ones(ksize) / ksize
            aug = cv2.filter2D(aug, -1, kernel)

    # Compression — 40% chance
    if np.random.random() < 0.4:
        quality = np.random.randint(55, 85)
        encode_param = [int(cv2.IMWRITE_JPEG_QUALITY), quality]
        _, encoded = cv2.imencode('.jpg', aug, encode_param)
        aug = cv2.imdecode(encoded, cv2.IMREAD_COLOR)

    return aug

aug_count = 0
skipped_dark = 0
skipped_empty = 0
skipped_no_img = 0

for lbl_file in os.listdir(src_lbl):
    if not lbl_file.endswith('.txt'):
        continue

    stem = Path(lbl_file).stem

    img_path = None
    for ext in ['.jpg', '.jpeg', '.png']:
        p = f"{src_img}/{stem}{ext}"
        if os.path.exists(p):
            img_path = p
            break
    if not img_path:
        skipped_no_img += 1
        continue

    with open(f"{src_lbl}/{lbl_file}") as f:
        lines = [l.strip().split() for l in f if l.strip()]

    if not lines:
        skipped_empty += 1
        continue

    brightness, sharpness = get_quality(img_path)
    if brightness is None:
        continue

    if brightness < MIN_BRIGHTNESS:
        skipped_dark += 1
        continue

    img = cv2.imread(img_path)

    for i in range(n_augmentations):
        aug = augment_image(img, brightness, sharpness)

        out_name = f"aug_{stem}_{i}"
        cv2.imwrite(f"{dst_img}/{out_name}.jpg", aug)

        with open(f"{dst_lbl}/{out_name}.txt", 'w') as f:
            for l in lines:
                f.write(' '.join(l) + '\n')

        aug_count += 1

print(f"Generated {aug_count} augmented images")
print(f"Skipped {skipped_dark} dark images")
print(f"Skipped {skipped_empty} empty label files")
print(f"Skipped {skipped_no_img} missing images")

# Create yaml
data = {
    'path': os.path.abspath("dataset"),
    'train': [
        'images/train_no_civ',
        'images/train_no_civ_aug_x1',
    ],
    'val': 'images/val_no_civ',
    'test': 'images/test_no_civ',
    'nc': 2,
    'names': ['soldier', 'barrier'],
}

with open("dataset/data_2class_aug_x1.yaml", 'w') as f:
    yaml.dump(data, f, default_flow_style=False)

print("Saved: dataset/data_2class_aug_x1.yaml")
